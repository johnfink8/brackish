{
  "name": "brackish-cli",
  "version": "0.1.0",
  "description": "Claude-to-Claude contract negotiation: a message bus + propose/accept artifact lifecycle for two Claude Code instances co-developing paired components.",
  "type": "module",
  "bin": {
    "brackish": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skill",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "dev": "tsx src/cli.ts"
  },
  "author": "John Fink <johnfink8@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnfink/brackish"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "contract",
    "negotiation",
    "api",
    "rpc"
  ],
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.3",
    "hono": "^4.12.19",
    "smol-toml": "^1.6.1",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
