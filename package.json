{
  "name": "brackish-cli",
  "version": "0.5.3",
  "description": "Claude-to-Claude contract negotiation: OpenAPI 3.1 propose/accept lifecycle (endpoints + schemas + convention), JSON-Patch diffs, browser UI via Swagger UI. For two Claude Code instances co-developing paired components.",
  "type": "module",
  "bin": {
    "brackish": "dist/cli.js"
  },
  "files": [
    "dist",
    "skill",
    "scripts/check-node.cjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preinstall": "node scripts/check-node.cjs",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "dev": "tsx src/cli.ts"
  },
  "author": "John Fink <johnfink8@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnfink8/brackish.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "contract",
    "negotiation",
    "api",
    "rpc"
  ],
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@seriousme/openapi-schema-validator": "^2.9.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.3",
    "hono": "^4.12.19",
    "smol-toml": "^1.6.1",
    "undici": "^7.25.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.0",
    "playwright": "^1.60.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
